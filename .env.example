# AI Provider: "gemini", "claude" or "openai"
AI_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Override model per provider (otherwise selectable in UI)
# GEMINI_MODEL=gemini-2.5-flash
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-5.4-mini

# App
PORT=3000
NODE_ENV=production
TZ=Europe/Berlin
UPLOAD_MAX_MB=25

# Job Worker Intervall in Sekunden
WORKER_INTERVAL_SEC=10
