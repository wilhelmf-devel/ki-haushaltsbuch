# ============================================================
# AUTHENTIFIZIERUNG (optional – Reverse-Proxy-basiert)
# ============================================================
# Wenn AUTH_HEADER gesetzt ist, liest die App den Benutzernamen
# aus diesem HTTP-Header. Der Reverse Proxy (nginx, Traefik, ...)
# ist für die eigentliche Authentifizierung zuständig.
# Fehlt der Header in einer Anfrage, antwortet die App mit 403.
#
# AUTH_ADMINS: kommagetrennte Liste von Admin-Benutzernamen.
# Admins haben Zugriff auf die Benutzerverwaltung.
#
# Wenn das Feature NICHT aktiv ist (AUTH_HEADER auskommentiert),
# verhält sich die App wie bisher: kein Zugriffsschutz, alle
# Mandanten für alle sichtbar.
# ============================================================
# AUTH_HEADER=X-Forwarded-User
# AUTH_ADMINS=alice,bob

# AI Provider: "gemini", "claude" or "openai"
AI_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Override model per provider (otherwise selectable in UI)
# GEMINI_MODEL=gemini-2.5-flash-lite
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-5.4-mini

# App
PORT=3000
NODE_ENV=production
TZ=Europe/Berlin
UPLOAD_MAX_MB=25

# Job Worker Intervall in Sekunden
WORKER_INTERVAL_SEC=10
