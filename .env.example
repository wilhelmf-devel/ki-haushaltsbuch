# ============================================================
# AUTHENTICATION (optional – reverse-proxy-based)
# ============================================================
# When AUTH_HEADER is set, the app reads the username from that
# HTTP header. The reverse proxy (nginx, Traefik, Caddy …) is
# responsible for the actual authentication.
# If the header is missing from a request, the app responds 403.
#
# AUTH_ADMINS: comma-separated list of admin usernames.
# Admins have access to the user management page.
#
# When this feature is NOT active (AUTH_HEADER commented out),
# the app behaves as before: no access control, all tenants
# visible to everyone.
# ============================================================
# AUTH_HEADER=X-Forwarded-User
# AUTH_ADMINS=alice,bob

# AI Provider: "gemini", "claude" or "openai"
AI_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Override model per provider (otherwise selectable in UI)
# GEMINI_MODEL=gemini-2.5-flash-lite
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-5.4-mini

# App
PORT=3000
NODE_ENV=production
TZ=Europe/Berlin
UPLOAD_MAX_MB=25

# Job worker polling interval in seconds
WORKER_INTERVAL_SEC=10
